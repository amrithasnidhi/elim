# ── LLM APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # Phase 6+: embeddings, TTS, Whisper, DALL-E

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017

# ── Auth (Phase 2) ─────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_hex

# ── Encryption (Phase 5) ───────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# ── App URLs (Phase 5) ─────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── OAuth — Google Drive (Phase 5) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Notion (Phase 5) ──────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── OAuth — GitHub (Phase 5) ──────────────────────────────
# Option A: OAuth app (full flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Option B: Personal Access Token — paste directly in Settings UI

# ── OAuth — Slack (Phase 5) ───────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Redis / Celery (Phase 6) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vector DB (Phase 6) ────────────────────────────────────
# Docker: CHROMADB_HOST=chromadb  |  Local dev: leave blank → uses PersistentClient
CHROMADB_HOST=
CHROMADB_PORT=8001
# Local dev path (used when CHROMADB_HOST is blank)
CHROMADB_PATH=./chromadb_data

# ── Storage (Phase 7) ──────────────────────────────────────
S3_BUCKET_NAME=elim-audio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=           # Leave blank for AWS S3, set for Cloudflare R2

# ── TTS (Phase 7) ──────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Observability (Phase 8) ────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false

# ── Frontend (set in frontend/.env.local) ─────────────────
VITE_API_URL=http://localhost:8000
