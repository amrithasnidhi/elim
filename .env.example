# App
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
DATABASE_NAME=elim
SECRET_KEY=replace_with_app_secret

# AI Providers
# Primary LLM — fill when you have credits
ANTHROPIC_API_KEY=
# Fallback LLM — free, no card (console.groq.com)
GROQ_API_KEY=
# Embeddings + TTS fallback — free (aistudio.google.com)
GEMINI_API_KEY=
# Primary TTS — free 10K credits/month (elevenlabs.io)
ELEVENLABS_API_KEY=

# Image APIs
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Search APIs
BRAVE_SEARCH_API_KEY=

# Database and Cache
MONGODB_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0

# Auth and Encryption
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_hex
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# OAuth Integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Slack removed — not needed for Phase 1-8

# Vector Store
# Local dev: leave CHROMADB_HOST blank → uses PersistentClient
# Docker: CHROMADB_HOST=chromadb
CHROMADB_HOST=
CHROMADB_PORT=8001
CHROMADB_PATH=./chromadb_data
# Prod only — fill at deployment (pinecone.io free Starter, no card)
# IMPORTANT: create index with 768 dimensions (Gemini embeddings, NOT 1536)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=elim-embeddings

# Storage — Cloudflare R2 (free 10GB, zero egress cost)
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=elim-audio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# TTS
# Primary: ElevenLabs — falls back to Gemini if blank, credits over, or any API error
ELEVENLABS_API_KEY=

# Observability — fill at Phase 8 (sentry.io + smith.langchain.com, both free)
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
